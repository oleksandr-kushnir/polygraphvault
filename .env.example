# Required local credentials. Copy to .env and replace every change-me value.
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=change-me-database-password
POSTGRES_PORT=5432
NEXTCLOUD_DB_PASSWORD=change-me-different-nextcloud-db-password
SYNCER_DB_PASSWORD=change-me-different-syncer-db-password

NEXTCLOUD_PORT=8088
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-nextcloud-password
# The syncer uses one Nextcloud service identity. Mappings select folders, not credentials.
NEXTCLOUD_SYNC_USER=admin
NEXTCLOUD_SYNC_PASSWORD=change-me-nextcloud-password

POLYGRAPHRAG_PORT=9622
POLYGRAPHRAG_API_TOKENS=
OPENAI_API_KEY=
LLM_MODEL=gpt-5.4-mini
LLM_BASE_URL=
LLM_API_KEY=
QUERY_LLM_MODEL=
QUERY_LLM_BASE_URL=
QUERY_LLM_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
VISION_MODEL=gpt-5.4-mini
VISION_BASE_URL=
VISION_API_KEY=
WHISPER_MODEL=whisper-1
WHISPER_BASE_URL=
WHISPER_API_KEY=

SYNCER_PORT=9630
SYNCER_API_TOKEN=
SYNC_POLL_INTERVAL=30
SYNC_DELETE_GRACE_SECS=300
SYNC_MAX_FILE_MB=200
SYNC_INGEST_TIMEOUT=900
SYNC_CANARY_AUTOCREATE=true

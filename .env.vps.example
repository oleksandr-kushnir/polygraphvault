# Copy this file to .env on the VPS and replace every change-me value.
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=change-me-long-random-database-password
POSTGRES_PORT=5432
NEXTCLOUD_DB_PASSWORD=change-me-different-nextcloud-db-password
SYNCER_DB_PASSWORD=change-me-different-syncer-db-password

# Reviewed published image digests (refresh deliberately during maintenance).
POLYGRAPHRAG_IMAGE=ghcr.io/oleksandr-kushnir/polygraphrag@sha256:d08c2b699e6c1e687d5b95c587b0cf76c6beebdb6a90dfdc19cb53e24c93dfa0
POLYGRAPHRAG_POSTGRES_IMAGE=ghcr.io/oleksandr-kushnir/polygraphrag-postgres@sha256:3b6608624c5a8bd905063984ff5fbccfacfab7c6dafe0da3f269273525d60202
NEXTCLOUD_IMAGE=nextcloud@sha256:35170a1c67e759ef874eaa0fde74eb223cf221dacfb67a8ccc14e8d7c5f2c990
REDIS_IMAGE=redis@sha256:6ab0b6e7381779332f97b8ca76193e45b0756f38d4c0dcda72dbb3c32061ab99
CADDY_IMAGE=caddy@sha256:5f5c8640aae01df9654968d946d8f1a56c497f1dd5c5cda4cf95ab7c14d58648

NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-long-random-admin-password
NEXTCLOUD_SYNC_USER=sync-worker
NEXTCLOUD_SYNC_PASSWORD=change-me-use-a-nextcloud-app-password
NEXTCLOUD_PORT=8088

# DNS A/AAAA records for both names must point at the VPS.
ACME_EMAIL=ops@example.com
NEXTCLOUD_DOMAIN=cloud.example.com
POLYGRAPHRAG_DOMAIN=rag.example.com
POLYGRAPHRAG_API_TOKENS=change-me-32-byte-or-longer-random-token
SYNCER_API_TOKEN=change-me-different-32-byte-or-longer-random-token
PUBLIC_UPLOAD_LIMIT=250MB

POSTGRES_DATA_DIR=/srv/polygraphvault/postgres
POLYGRAPHRAG_DATA_DIR=/srv/polygraphvault/polygraphrag
REDIS_DATA_DIR=/srv/polygraphvault/redis
NEXTCLOUD_HTML_DIR=/srv/polygraphvault/nextcloud
CADDY_DATA_DIR=/srv/polygraphvault/caddy-data
CADDY_CONFIG_DIR=/srv/polygraphvault/caddy-config

OPENAI_API_KEY=
LLM_MODEL=gpt-5.4-mini
LLM_BASE_URL=
LLM_API_KEY=
QUERY_LLM_MODEL=
QUERY_LLM_BASE_URL=
QUERY_LLM_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
VISION_MODEL=gpt-5.4-mini
VISION_BASE_URL=
VISION_API_KEY=
WHISPER_MODEL=whisper-1
WHISPER_BASE_URL=
WHISPER_API_KEY=

SYNC_POLL_INTERVAL=30
SYNC_DELETE_GRACE_SECS=300
SYNC_MAX_FILE_MB=200
SYNC_INGEST_TIMEOUT=900
SYNC_CANARY_AUTOCREATE=false
SYNC_EVENTS_RETENTION_DAYS=90
# Accept the API token via a ?token= URL parameter as a fallback when the
# Authorization header is absent. Local convenience only — leave false on the
# VPS: query strings leak into access logs, browser history, and Referer.
SYNCER_ALLOW_TOKEN_QUERY_PARAM=false
